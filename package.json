{
  "name": "jsyncd",
  "version": "1.0.6",
  "type": "module",
  "description": "live file monitor and rsync daemon",
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6",
    "daemon": "^1.1.0",
    "find-process": "^2.1.1",
    "rsync2": "^3.0.1",
    "unixify": "^1.0.0",
    "which": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "chai": "^6.2.2",
    "eslint": "^10.2.1",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "semistandard": "^17.0.0",
    "sinon": "^21.1.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">= 18.18.2"
  },
  "author": "Jacob Hundley <jhundley9109@gmail.com>",
  "bin": {
    "jsyncd": "./build/bin/index.js"
  },
  "scripts": {
    "pretest": "npm run tsc",
    "test": "nodemon --watch . --watch ~/.config/jsyncd/ --ext ts,json,mjs",
    "test_kill": "nodemon --watch . --watch ~/.config/jsyncd/ ./build/bin/index.js  --ext ts,json,mjs -- -k=1",
    "start": "node ./build/bin/index.js ",
    "prebuild": "npm run tsc",
    "build": "npm run start",
    "tsc": "tsc",
    "lint": "eslint . --ext ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jhundley9109/jsyncd"
  },
  "homepage": "https://github.com/jhundley9109/jsyncd#readme",
  "readmeFilename": "README.md",
  "license": "MIT",
  "keywords": [
    "rsync",
    "lsyncd",
    "chokidar",
    "file backup",
    "live sync",
    "directory mirroring"
  ]
}
